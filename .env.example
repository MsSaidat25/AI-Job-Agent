# Copy this file to .env and fill in your values

# ── LLM Provider (OpenRouter takes priority if both are set) ──────────────
OPENROUTER_API_KEY=sk-or-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
AGENT_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096

# ── Job Search (JSearch / RapidAPI) ───────────────────────────────────
# JSEARCH_API_KEY=your-rapidapi-key

# ── GCP (enables Secret Manager, Vertex AI, Cloud Run) ───────────────────
# GCP_PROJECT_ID=my-gcp-project
# VERTEX_PROJECT=my-gcp-project
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=claude-sonnet-4-6@20250514
# USE_VERTEX_PRIMARY=false
# USE_VERTEX_FAILOVER=true

# ── Database ──────────────────────────────────────────────────────────────
# Primary: Cloud SQL PostgreSQL
# DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance
# Failover: Supabase PostgreSQL
# DATABASE_URL_FAILOVER=postgresql://user:pass@db.xxx.supabase.co:5432/postgres
# Supabase keys (for future full switchover)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJ...
# SUPABASE_SERVICE_KEY=eyJ...

# ── Auth (Cloud Identity Platform) ───────────────────────────────────────
# AUTH_ENABLED=false
# GCP_IDENTITY_PLATFORM_API_KEY=AIza...

# ── Email (Resend) ───────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@example.com

# ── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (default: * for local dev)
# ALLOWED_ORIGINS=https://myapp.example.com,https://www.myapp.example.com

# ── Privacy & Agent ──────────────────────────────────────────────────────
ENCRYPT_USER_DATA=true
MAX_JOBS_PER_SEARCH=25
APPLICATION_COOLDOWN_DAYS=30
